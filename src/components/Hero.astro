---
const techPills = ['NestJS', 'Docker', 'PostgreSQL', 'Go', 'Git'];
---

<section
  id="home"
  class="relative min-h-screen flex items-center overflow-hidden pt-16"
  aria-labelledby="hero-heading"
>
  <!-- Background layers -->
  <div class="absolute inset-0 -z-10" aria-hidden="true">
    <div
      class="absolute inset-0 opacity-[0.12]"
      style="background-image: radial-gradient(circle, #6366f1 1px, transparent 1px); background-size: 32px 32px;"
    />
    <div class="absolute inset-0 bg-gradient-to-br from-indigo-950/30 via-transparent to-cyan-950/20" />
    <div class="absolute -top-48 -left-48 w-[500px] h-[500px] bg-indigo-600/15 rounded-full blur-3xl" />
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] bg-cyan-600/8 rounded-full blur-3xl" />
    <div class="absolute top-1/3 right-1/4 w-[300px] h-[300px] bg-violet-600/8 rounded-full blur-3xl" />
  </div>

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-20 lg:py-32 w-full">
    <div class="max-w-3xl">

      <!-- Availability badge -->
      <div
        class="inline-flex items-center gap-2 px-3.5 py-1.5 mb-8 text-xs font-semibold text-emerald-300 bg-emerald-500/10 border border-emerald-500/20 rounded-full"
        data-animate
      >
        <span class="relative flex h-2 w-2" aria-hidden="true">
          <span class="animate-ping absolute inline-flex h-full w-full rounded-full bg-emerald-400 opacity-75"></span>
          <span class="relative inline-flex rounded-full h-2 w-2 bg-emerald-400"></span>
        </span>
        Available for opportunities
      </div>

      <!-- Name -->
      <h1
        id="hero-heading"
        class="text-4xl sm:text-5xl lg:text-[3.75rem] font-extrabold tracking-tight leading-[1.1] mb-5"
        data-animate
        style="transition-delay: 0.08s;"
      >
        <span class="text-slate-100">Abdou Valerio<br /></span>
        <span class="bg-gradient-to-r from-indigo-400 via-purple-400 to-cyan-400 bg-clip-text text-transparent">
          Foma Kenfack
        </span>
      </h1>

      <!-- Role -->
      <p
        class="text-lg sm:text-xl font-semibold text-indigo-300/90 mb-6 tracking-wide"
        data-animate
        style="transition-delay: 0.16s;"
      >
        Computer Engineering Student &amp; Backend Developer
      </p>

      <!-- Pitch -->
      <p
        class="text-base sm:text-lg text-slate-400 leading-[1.8] max-w-2xl mb-10"
        data-animate
        style="transition-delay: 0.24s;"
      >
        I specialize in building
        <strong class="text-slate-200 font-medium">secure, containerized backend systems</strong>
        and transitioning complex business logic into
        <strong class="text-slate-200 font-medium">scalable microservices</strong>.
        Currently studying Computer Engineering at Bitlis Eren University while shipping real-world backend systems.
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-3" data-animate style="transition-delay: 0.32s;">
        <a
          href="#projects"
          class="inline-flex items-center gap-2 px-6 py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-indigo-500/20 hover:shadow-indigo-500/35 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0f]"
        >
          View Projects
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M5 12h14M12 5l7 7-7 7" />
          </svg>
        </a>
        <a
          href="https://github.com/FKAV64"
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/8 text-slate-300 hover:text-white text-sm font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all duration-200 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0f]"
        >
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
          </svg>
          GitHub
        </a>
        <a
          href="#contact"
          class="inline-flex items-center gap-2 px-6 py-3 bg-white/5 hover:bg-white/8 text-slate-300 hover:text-white text-sm font-semibold rounded-xl border border-white/10 hover:border-white/20 transition-all duration-200 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-slate-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0f]"
        >
          Contact
        </a>
      </div>

      <!-- Tech pills -->
      <div class="mt-12 flex flex-wrap gap-2" data-animate style="transition-delay: 0.4s;">
        <span class="text-xs text-slate-600 self-center mr-1">Stack:</span>
        {techPills.map((tech) => (
          <span class="px-3 py-1 text-xs font-medium text-slate-500 bg-white/[0.04] border border-white/[0.08] rounded-full hover:text-slate-300 hover:border-white/20 transition-colors duration-200">
            {tech}
          </span>
        ))}
      </div>
    </div>
  </div>

  <!-- Scroll cue -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5" aria-hidden="true">
    <span class="text-[11px] text-slate-600 tracking-widest uppercase">Scroll</span>
    <svg
      width="14"
      height="14"
      viewBox="0 0 24 24"
      fill="none"
      stroke="#475569"
      stroke-width="2"
      stroke-linecap="round"
      class="animate-bounce"
    >
      <path d="M7 13l5 5 5-5" />
      <path d="M7 7l5 5 5-5" />
    </svg>
  </div>
</section>
