---
const coursework = [
  'Algorithm Analysis',
  'Digital Logic Design',
  'Data Structures',
  'Computer Networks',
  'Operating Systems',
  'Discrete Mathematics',
];
---

<section
  id="education"
  class="py-24 lg:py-32 bg-gray-950/40"
  aria-labelledby="education-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-indigo-400 tracking-[0.2em] uppercase mb-3">Academic</p>
      <h2 id="education-heading" class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">
        Education
      </h2>
      <p class="text-slate-400 max-w-xl leading-relaxed">
        Building a strong theoretical foundation alongside practical backend engineering work.
      </p>
    </div>

    <div class="max-w-3xl" data-animate style="transition-delay: 0.08s;">
      <div class="bg-gray-900/40 border border-white/[0.06] rounded-2xl p-7 hover:border-white/10 transition-colors duration-200">

        <!-- Header row -->
        <div class="flex flex-wrap items-start justify-between gap-4 mb-6">
          <div>
            <!-- Institution -->
            <div class="flex items-center gap-2.5 mb-1">
              <div class="w-8 h-8 rounded-lg bg-indigo-500/10 border border-indigo-500/20 flex items-center justify-center flex-shrink-0" aria-hidden="true">
                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#a5b4fc" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M22 10v6M2 10l10-5 10 5-10 5z" />
                  <path d="M6 12v5c3 3 9 3 12 0v-5" />
                </svg>
              </div>
              <h3 class="text-lg font-semibold text-slate-100">Bitlis Eren University</h3>
            </div>
            <p class="text-indigo-300/80 font-medium text-sm ml-[2.625rem]">B.S. Computer Engineering</p>
          </div>

          <!-- Status badge -->
          <div class="flex flex-col items-end gap-1.5">
            <span class="inline-flex items-center gap-1.5 px-3 py-1 text-xs font-semibold text-emerald-300 bg-emerald-500/10 border border-emerald-500/20 rounded-full">
              <span class="w-1.5 h-1.5 rounded-full bg-emerald-400 animate-pulse" aria-hidden="true" />
              In Progress
            </span>
            <span class="text-xs text-slate-500">4th Semester · 2022 — Present</span>
          </div>
        </div>

        <!-- Divider -->
        <div class="border-t border-white/5 mb-6" aria-hidden="true" />

        <!-- Stats row -->
        <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-6">
          <div class="bg-white/[0.03] border border-white/5 rounded-xl p-4 text-center">
            <p class="text-xs text-slate-500 mb-1">Semester</p>
            <p class="text-lg font-bold text-slate-200">4th</p>
          </div>
          <div class="bg-white/[0.03] border border-white/5 rounded-xl p-4 text-center">
            <p class="text-xs text-slate-500 mb-1">GPA</p>
            <p class="text-lg font-bold text-slate-200">Solid</p>
          </div>
          <div class="bg-white/[0.03] border border-white/5 rounded-xl p-4 text-center col-span-2 sm:col-span-1">
            <p class="text-xs text-slate-500 mb-1">Focus</p>
            <p class="text-sm font-bold text-slate-200 leading-tight">Backend &amp; Security</p>
          </div>
        </div>

        <!-- Coursework -->
        <div>
          <p class="text-xs font-semibold text-slate-400 uppercase tracking-widest mb-3">Relevant Coursework</p>
          <div class="flex flex-wrap gap-2">
            {coursework.map((course) => (
              <span class="px-3 py-1.5 text-xs font-medium text-slate-400 bg-white/[0.04] border border-white/[0.08] rounded-lg hover:text-slate-300 hover:border-white/15 transition-colors">
                {course}
              </span>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
