---
const groups = [
  {
    category: 'Core',
    description: 'Production-ready technologies I rely on daily',
    skills: ['NestJS', 'Docker', 'PostgreSQL', 'Git Workflows'],
    headerColor: 'text-indigo-300',
    borderColor: 'border-indigo-500/20',
    bgColor: 'bg-indigo-500/[0.06]',
    dotColor: 'bg-indigo-400',
    tagBase: 'bg-indigo-500/10 text-indigo-200 border border-indigo-500/20',
    badgeBg: 'bg-indigo-500/15 text-indigo-300',
  },
  {
    category: 'Familiar',
    description: 'Tools and languages I actively explore and apply',
    skills: ['Go', 'Astro', 'Tailwind CSS'],
    headerColor: 'text-cyan-300',
    borderColor: 'border-cyan-500/20',
    bgColor: 'bg-cyan-500/[0.06]',
    dotColor: 'bg-cyan-400',
    tagBase: 'bg-cyan-500/10 text-cyan-200 border border-cyan-500/20',
    badgeBg: 'bg-cyan-500/15 text-cyan-300',
  },
  {
    category: 'Focus Areas',
    description: 'Domains I am deliberately building depth in',
    skills: ['Cybersecurity', 'Container Hardening'],
    headerColor: 'text-violet-300',
    borderColor: 'border-violet-500/20',
    bgColor: 'bg-violet-500/[0.06]',
    dotColor: 'bg-violet-400',
    tagBase: 'bg-violet-500/10 text-violet-200 border border-violet-500/20',
    badgeBg: 'bg-violet-500/15 text-violet-300',
  },
];
---

<section
  id="skills"
  class="py-24 lg:py-32 bg-gray-950/40"
  aria-labelledby="skills-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-indigo-400 tracking-[0.2em] uppercase mb-3">Expertise</p>
      <h2 id="skills-heading" class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">
        Technical Skills
      </h2>
      <p class="text-slate-400 max-w-xl leading-relaxed">
        Organized by depth and daily use — from production mainstays to deliberate growth areas.
      </p>
    </div>

    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        groups.map((group, i) => (
          <div
            class={`rounded-2xl border ${group.borderColor} ${group.bgColor} p-6`}
            data-animate
            style={`transition-delay: ${i * 0.1 + 0.05}s;`}
          >
            <!-- Card header -->
            <div class="flex items-center justify-between mb-5">
              <div class="flex items-center gap-2.5">
                <span class={`w-2 h-2 rounded-full ${group.dotColor}`} aria-hidden="true" />
                <h3 class={`text-sm font-semibold ${group.headerColor}`}>{group.category}</h3>
              </div>
              <span class={`text-[10px] font-semibold px-2 py-0.5 rounded-full ${group.badgeBg}`}>
                {group.skills.length} {group.skills.length === 1 ? 'skill' : 'skills'}
              </span>
            </div>

            <!-- Description -->
            <p class="text-xs text-slate-500 mb-5 leading-relaxed">{group.description}</p>

            <!-- Skills -->
            <div class="flex flex-wrap gap-2">
              {group.skills.map((skill) => (
                <span class={`px-3 py-1.5 text-sm font-medium rounded-lg ${group.tagBase}`}>
                  {skill}
                </span>
              ))}
            </div>
          </div>
        ))
      }
    </div>

    <!-- Additional context -->
    <div
      class="mt-8 p-5 rounded-2xl border border-white/5 bg-white/[0.02] flex items-start gap-4"
      data-animate
      style="transition-delay: 0.35s;"
    >
      <div class="w-8 h-8 rounded-lg bg-amber-500/10 border border-amber-500/20 flex items-center justify-center flex-shrink-0 mt-0.5" aria-hidden="true">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#fbbf24" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2" />
        </svg>
      </div>
      <div>
        <p class="text-sm font-medium text-slate-300 mb-1">Actively learning</p>
        <p class="text-sm text-slate-500 leading-relaxed">
          Deepening knowledge in container security hardening, network threat modeling, and Go's
          concurrency patterns for high-throughput backend services.
        </p>
      </div>
    </div>
  </div>
</section>
