---
const projects = [
  {
    title: 'Smart Logistics',
    subtitle: 'Sivas Hackathon',
    description:
      'Delivered under hackathon conditions to tackle real-world logistics routing challenges. The entire stack runs in isolated Docker containers with optimized networking, volume management, health checks, and restart policies engineered for demo-day reliability.',
    focus: 'Dockerized deployment & container optimization',
    tags: ['Docker', 'Docker Compose', 'Nginx', 'Linux', 'REST API'],
    borderHover: 'hover:border-indigo-500/50',
    borderBase: 'border-indigo-500/15',
    badgeBg: 'bg-indigo-500/10 text-indigo-300 border border-indigo-500/20',
    dot: 'bg-indigo-400',
    tagBg: 'bg-indigo-500/10 text-indigo-300',
    glow: 'hover:shadow-indigo-500/10',
    github: '',
  },
  {
    title: 'School Management API',
    subtitle: 'Full-stack Backend',
    description:
      'A comprehensive REST API for educational institutions featuring multi-role JWT authentication (Admin / Teacher / Student), automated fee tracking with payment history, enrollment management, and structured audit logging for institutional compliance.',
    focus: 'Secure auth, fee tracking & RBAC',
    tags: ['NestJS', 'PostgreSQL', 'JWT', 'RBAC', 'TypeORM'],
    borderHover: 'hover:border-cyan-500/50',
    borderBase: 'border-cyan-500/15',
    badgeBg: 'bg-cyan-500/10 text-cyan-300 border border-cyan-500/20',
    dot: 'bg-cyan-400',
    tagBg: 'bg-cyan-500/10 text-cyan-300',
    glow: 'hover:shadow-cyan-500/10',
    github: 'https://github.com/FKAV64',
  },
  {
    title: 'Microservices Architecture',
    subtitle: 'Distributed Systems',
    description:
      'A polyglot microservices backend demonstrating API gateway routing, service isolation, and independent deployment pipelines. Individual services written in NestJS and Go communicate over a shared PostgreSQL backend with clear domain boundaries.',
    focus: 'Routing & multi-component systems',
    tags: ['NestJS', 'Go', 'PostgreSQL', 'Docker', 'API Gateway'],
    borderHover: 'hover:border-violet-500/50',
    borderBase: 'border-violet-500/15',
    badgeBg: 'bg-violet-500/10 text-violet-300 border border-violet-500/20',
    dot: 'bg-violet-400',
    tagBg: 'bg-violet-500/10 text-violet-300',
    glow: 'hover:shadow-violet-500/10',
    github: '',
  },
];
---

<section id="projects" class="py-24 lg:py-32 relative" aria-labelledby="projects-heading">
  <div class="absolute inset-0 -z-10 bg-gradient-to-b from-transparent via-indigo-950/[0.04] to-transparent" aria-hidden="true" />

  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-indigo-400 tracking-[0.2em] uppercase mb-3">Portfolio</p>
      <h2 id="projects-heading" class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">
        Selected Projects
      </h2>
      <p class="text-slate-400 max-w-xl leading-relaxed">
        A focused set of backend systems built around real constraints — containerization, security,
        and scalability front and center.
      </p>
    </div>

    <!-- Grid -->
    <div class="grid md:grid-cols-2 lg:grid-cols-3 gap-5">
      {
        projects.map((project, i) => (
          <article
            class={`group relative flex flex-col bg-gray-900/40 border ${project.borderBase} ${project.borderHover} rounded-2xl p-6 transition-all duration-300 hover:bg-gray-900/70 hover:-translate-y-1 hover:shadow-xl ${project.glow}`}
            data-animate
            style={`transition-delay: ${i * 0.1 + 0.05}s;`}
          >
            <!-- Header -->
            <div class="flex items-start justify-between gap-3 mb-4">
              <div class="min-w-0">
                <span class={`inline-block px-2.5 py-0.5 text-[11px] font-semibold rounded-full mb-2 ${project.badgeBg}`}>
                  {project.subtitle}
                </span>
                <h3 class="text-base font-semibold text-slate-100 leading-snug">{project.title}</h3>
              </div>
              <svg
                width="18"
                height="18"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="1.5"
                stroke-linecap="round"
                stroke-linejoin="round"
                class="text-slate-700 group-hover:text-slate-500 transition-colors flex-shrink-0 mt-1"
                aria-hidden="true"
              >
                <path d="M9 3H5a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-4" />
                <polyline points="15 3 21 3 21 9" />
                <line x1="10" y1="14" x2="21" y2="3" />
              </svg>
            </div>

            <!-- Focus line -->
            <div class="flex items-center gap-2 mb-3.5">
              <span class={`w-1.5 h-1.5 rounded-full flex-shrink-0 ${project.dot}`} aria-hidden="true" />
              <span class="text-[11px] font-medium text-slate-500 uppercase tracking-wide">{project.focus}</span>
            </div>

            <!-- Description -->
            <p class="text-sm text-slate-500 leading-[1.75] flex-grow mb-5">
              {project.description}
            </p>

            <!-- Tags -->
            <div class="flex flex-wrap gap-1.5 mb-4">
              {project.tags.map((tag) => (
                <span class={`px-2 py-0.5 text-[11px] font-medium rounded-md ${project.tagBg}`}>
                  {tag}
                </span>
              ))}
            </div>

            <!-- GitHub link -->
            {project.github && (
              <a
                href={project.github}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1.5 text-xs text-slate-600 hover:text-slate-300 transition-colors mt-auto pt-3 border-t border-white/5"
                aria-label={`View ${project.title} source on GitHub`}
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z" />
                </svg>
                View on GitHub
                <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" aria-hidden="true">
                  <path d="M7 17L17 7M7 7h10v10" />
                </svg>
              </a>
            )}
          </article>
        ))
      }
    </div>
  </div>
</section>
