---
const contactLinks = [
  {
    label: 'GitHub',
    username: '@FKAV64',
    href: 'https://github.com/FKAV64',
    description: 'Explore my open-source projects and contributions',
    external: true,
    iconPath: `M12 2C6.477 2 2 6.484 2 12.017c0 4.425 2.865 8.18 6.839 9.504.5.092.682-.217.682-.483 0-.237-.008-.868-.013-1.703-2.782.605-3.369-1.343-3.369-1.343-.454-1.158-1.11-1.466-1.11-1.466-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.113-4.555-4.951 0-1.093.39-1.988 1.029-2.688-.103-.253-.446-1.272.098-2.65 0 0 .84-.27 2.75 1.026A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.296 2.747-1.027 2.747-1.027.546 1.379.202 2.398.1 2.651.64.7 1.028 1.595 1.028 2.688 0 3.848-2.339 4.695-4.566 4.943.359.309.678.92.678 1.855 0 1.338-.012 2.419-.012 2.747 0 .268.18.58.688.482A10.019 10.019 0 0022 12.017C22 6.484 17.522 2 12 2z`,
    iconFill: true,
    borderColor: 'border-indigo-500/20',
    hoverBorder: 'hover:border-indigo-500/50',
    bgColor: 'bg-indigo-500/[0.06]',
    iconColor: '#818cf8',
    iconBg: 'bg-indigo-500/10 border-indigo-500/20',
    usernameColor: 'text-indigo-300',
  },
  {
    label: 'LinkedIn',
    username: 'Abdou V. F. Kenfack',
    href: 'https://linkedin.com/in/abdou-kenfack',
    description: 'Connect with me professionally and view my career timeline',
    external: true,
    iconPath: `M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6zM2 9h4v12H2z M4 6a2 2 0 1 0 0-4 2 2 0 0 0 0 4z`,
    iconFill: false,
    borderColor: 'border-cyan-500/20',
    hoverBorder: 'hover:border-cyan-500/50',
    bgColor: 'bg-cyan-500/[0.06]',
    iconColor: '#22d3ee',
    iconBg: 'bg-cyan-500/10 border-cyan-500/20',
    usernameColor: 'text-cyan-300',
  },
  {
    label: 'Email',
    username: 'kenfackabdou0@gmail.com',
    href: 'mailto:kenfackabdou0@gmail.com',
    description: 'Preferred channel for project inquiries and opportunities',
    external: false,
    iconPath: `M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z M22 6l-10 7L2 6`,
    iconFill: false,
    borderColor: 'border-violet-500/20',
    hoverBorder: 'hover:border-violet-500/50',
    bgColor: 'bg-violet-500/[0.06]',
    iconColor: '#a78bfa',
    iconBg: 'bg-violet-500/10 border-violet-500/20',
    usernameColor: 'text-violet-300',
  },
];
---

<section
  id="contact"
  class="py-24 lg:py-32 bg-gray-950/40"
  aria-labelledby="contact-heading"
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <!-- Section header -->
    <div class="mb-16" data-animate>
      <p class="text-xs font-semibold text-indigo-400 tracking-[0.2em] uppercase mb-3">Get In Touch</p>
      <h2 id="contact-heading" class="text-3xl sm:text-4xl font-bold text-slate-100 mb-4">
        Contact
      </h2>
      <p class="text-slate-400 max-w-xl leading-relaxed">
        Open to backend engineering roles, collaborative projects, and hackathon partnerships.
        The fastest way to reach me is email.
      </p>
    </div>

    <!-- Contact cards -->
    <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-5 mb-12">
      {
        contactLinks.map((link, i) => (
          <a
            href={link.href}
            target={link.external ? '_blank' : undefined}
            rel={link.external ? 'noopener noreferrer' : undefined}
            class={`group flex flex-col gap-4 bg-gray-900/40 border ${link.borderColor} ${link.hoverBorder} ${link.bgColor} rounded-2xl p-6 hover:bg-gray-900/70 hover:-translate-y-1 transition-all duration-300 hover:shadow-xl hover:shadow-black/20 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0f]`}
            data-animate
            style={`transition-delay: ${i * 0.1 + 0.05}s;`}
            aria-label={`${link.label}: ${link.username}`}
          >
            <!-- Icon and label -->
            <div class="flex items-center justify-between">
              <div class={`w-10 h-10 rounded-xl border ${link.iconBg} flex items-center justify-center`} aria-hidden="true">
                <svg
                  width="18"
                  height="18"
                  viewBox="0 0 24 24"
                  fill={link.iconFill ? link.iconColor : 'none'}
                  stroke={link.iconFill ? 'none' : link.iconColor}
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d={link.iconPath} />
                </svg>
              </div>
              <svg
                width="14"
                height="14"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                class="text-slate-600 group-hover:text-slate-400 transition-colors"
                aria-hidden="true"
              >
                <path d="M7 17L17 7M7 7h10v10" />
              </svg>
            </div>

            <!-- Content -->
            <div>
              <p class="text-xs font-semibold text-slate-500 uppercase tracking-widest mb-1">{link.label}</p>
              <p class={`text-sm font-semibold break-all ${link.usernameColor}`}>{link.username}</p>
              <p class="text-xs text-slate-500 mt-1.5 leading-relaxed">{link.description}</p>
            </div>
          </a>
        ))
      }
    </div>

    <!-- CTA block -->
    <div
      class="relative overflow-hidden rounded-2xl border border-indigo-500/20 bg-gradient-to-br from-indigo-950/50 via-[#0a0a0f] to-violet-950/30 p-8 text-center"
      data-animate
      style="transition-delay: 0.35s;"
    >
      <div class="absolute inset-0 opacity-[0.06]" style="background-image: radial-gradient(circle, #6366f1 1px, transparent 1px); background-size: 24px 24px;" aria-hidden="true" />
      <div class="relative z-10">
        <h3 class="text-xl font-bold text-slate-100 mb-2">Ready to build something together?</h3>
        <p class="text-slate-400 text-sm mb-6 max-w-md mx-auto leading-relaxed">
          Whether it's a backend system, a containerized deployment, or an open-source collaboration — drop me a line.
        </p>
        <a
          href="mailto:kenfackabdou0@gmail.com"
          class="inline-flex items-center gap-2 px-7 py-3 bg-indigo-600 hover:bg-indigo-500 text-white text-sm font-semibold rounded-xl transition-all duration-200 shadow-lg shadow-indigo-500/25 hover:shadow-indigo-500/40 hover:-translate-y-0.5 focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:ring-offset-2 focus:ring-offset-[#0a0a0f]"
        >
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <rect width="20" height="16" x="2" y="4" rx="2" />
            <path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7" />
          </svg>
          Send a Message
        </a>
      </div>
    </div>
  </div>
</section>
